NSC_API_BASE=https://your-real-nsc-api.example.com/api
PORT=4000

# ========== FINNHUB API CONFIGURATION ==========
# Get FREE API key from: https://finnhub.io
# 1. Sign up at https://finnhub.io/ (free tier)
# 2. Go to Dashboard → Get API Key
# 3. Copy and paste below
# Free tier: 60 API calls/minute (plenty for our use)

FINNHUB_API_KEY=YOUR_FINNHUB_API_KEY

# ========== SHEETDB CONFIGURATION ==========
# Enable SheetDB price fetching (true/false)
# Set to false to use only live Finnhub market prices
# Default: false

ENABLE_SHEETDB=false
